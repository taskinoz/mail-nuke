IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USERNAME=you@example.com
IMAP_PASSWORD=your-app-password
IMAP_USE_SSL=true

IMAP_SOURCE_FOLDER=INBOX
IMAP_SPAM_FOLDER=Junk
IMAP_POLL_SECONDS=60

SPAM_THRESHOLD=0.90 # The threshold above which an email is considered spam.
MARK_SEEN_ON_SPAM=true # Whether to mark emails as seen when they are moved to the spam folder.
DRY_RUN=true # If true, actions will be logged but not executed. Set to false to actually move emails.
PROCESS_ONLY_UNSEEN=true # If true, only process emails that are unseen.

STATE_FILENAME=imap-worker-state.json
ACTION_LOG_FILENAME=imap-actions.jsonl